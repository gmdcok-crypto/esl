# SoluM AIMS SaaS (Asia region)
AIMS_BASE_URL=https://asia.common.solumesl.com
AIMS_USERNAME=your-admin-email@example.com
AIMS_PASSWORD=your-admin-password
AIMS_STORE_ID=0001
AIMS_COMPANY_CODE=BLU
AIMS_TENANT_ID=

# Optional override (default: {AIMS_BASE_URL}/common/api/v2)
# AIMS_API_BASE_URL=https://asia.common.solumesl.com/common/api/v2

# App login (PWA) — long-lived JWT
APP_USERNAME=admin
APP_PASSWORD=change-me
APP_JWT_SECRET=replace-with-a-long-random-secret
# Optional: seconds (default ~20 years)
# APP_JWT_TTL_SEC=630720000

# Railway MySQL (add MySQL plugin and link to this service)
# Railway injects MYSQL_URL or MYSQLHOST / MYSQLPORT / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE
# MYSQL_URL=mysql://user:password@host:3306/railway
# Or use DATABASE_URL as an alias

# Optional webhook secret for legacy webhook route
WEBHOOK_SECRET=

# Railway sets PORT automatically
PORT=3000
